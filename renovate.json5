{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:best-practices",
    ":automergeBranch",
    ":automergePatch",
    ":automergeDigest",
    ":skipStatusChecks",
    ":disableRateLimiting",
    ":dependencyDashboard",
    ":pinDigestsDisabled", // https://github.com/renovatebot/renovate/issues/29768
    "group:allDigest",
  ],
  recreateWhen: "always",
  dependencyDashboardTitle: 'Renovate Dashboard',
  suppressNotifications: [ 'prIgnoreNotification' ],
  commitMessageTopic: '{{depName}}',
  commitMessageExtra: 'to {{newVersion}}',
  ignoreDeps: [
    'ghcr.io/fluxcd/helm-controller',
    'ghcr.io/fluxcd/image-automation-controller',
    'ghcr.io/fluxcd/image-reflector-controller',
    'ghcr.io/fluxcd/kustomize-controller',
    'ghcr.io/fluxcd/notification-controller',
    'ghcr.io/fluxcd/source-controller',
    'ghcr.io/vaskozl/baikal',
    'ghcr.io/vaskozl/rspamd',
  ],
  flux: { managerFilePatterns: [ '/cluster/.+\\.ya?ml$/' ] },
  'helm-values': { managerFilePatterns: [ '/cluster/.+\\.ya?ml$/' ] },
  kubernetes: { managerFilePatterns: [ '/cluster/.+\\.ya?ml$/' ] },
  'docker-compose': { managerFilePatterns: [ '/nas/.+\\.ya?ml$/' ] },
  packageRules: [
    {
      matchDatasources: [ 'helm' ],
      commitMessageTopic: 'chart {{depName}}',
    },
    {
      matchDatasources: [ 'docker' ],
      commitMessageTopic: 'image {{depName}}',
    },
    // Automerge minor for these allowlist
    {
      matchDatasources: [
        'docker',
      ],
      matchPackageNames: [
        'ghcr.io/gethomepage/homepage',
        'ghcr.io/vaskozl/cyberchef-web',
        'ghcr.io/vaskozl/k8s-sidecar',
        'ghcr.io/vaskozl/kubeconform',
        'ghcr.io/vaskozl/oauth2-proxy',
      ],
      matchUpdateTypes: [
        'minor',
      ],
      automerge: true,
    },
    // Automerge major using dates
    {
      matchDatasources: [
        'docker',
      ],
      matchPackageNames: [
        'ghcr.io/vaskozl/cloudflared',
        'ghcr.io/home-assistant/home-assistant',
        'ghcr.io/vaskozl/renovate',
      ],
      matchUpdateTypes: [
        'major', 'minor',
      ],
      automerge: true,
    },
    {
      matchDatasources: [
        'docker',
      ],
      groupName: 'immich',
      sourceUrl: 'https://github.com/immich-app/immich',
      matchPackageNames: [
        '/^ghcr\\.io/immich-app//',
      ],
    },
    {
      matchDatasources: [
        'docker',
      ],
      groupName: 'cert-manager',
      sourceUrl: 'https://github.com/cert-manager/cert-manager',
      matchPackageNames: [
        '/^ghcr\\.io/vaskozl/cert-manager-/',
      ],
    },
    {
      matchDatasources: [
        'docker',
      ],
      groupName: 'gitlab',
      sourceUrl: 'https://gitlab.com/gitlab-org/build/CNG/',
      matchPackageNames: [
        '/^ghcr\\.io/vaskozl/gitlab/',
        '/^ghcr\\.io/vaskozl/gitaly$/',
      ],
    },
    {
      // Major postgres upgrades require data directory migration (pg_upgrade
      // or dump/restore) and cannot be done via a simple image tag bump.
      // Block major updates for stateful postgres images; minor/patch still fine.
      matchDatasources: ['docker'],
      matchPackageNames: [
        'ghcr.io/vaskozl/postgresql',
        'ghcr.io/immich-app/postgres',
      ],
      matchUpdateTypes: ['major'],
      enabled: false,
    },
  ],
}
